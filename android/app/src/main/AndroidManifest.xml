<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />

    <!-- Screen capture -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- Write LED settings via Settings.System -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <!-- Keep CPU alive while service runs -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Notification for the foreground service (required Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="lightmeup"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:focusableInTouchMode="false"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Ambient LED foreground service -->
        <service
            android:name=".LightmeupService"
            android:foregroundServiceType="mediaProjection"
            android:exported="false" />

        <!--
            Quick Settings tile.

            android:exported="true"  — required so the system can bind to it.
            android:permission       — locks binding to the system tile manager only.
            The label / icon shown in the QS panel come from the <intent-filter>
            and from LightmeupTileService.requestTileAdd() at runtime.
        -->
        <service
            android:name=".LightmeupQSTile"
            android:exported="true"
            android:label="LightMeUp"
            android:icon="@mipmap/ic_launcher"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!--
            Lightweight transparent activity that handles the tile's
            WRITE_SETTINGS → MediaProjection permission flow.
            Translucent theme means the screen behind stays fully visible.
            Excluded from recents so it never appears in the task switcher.
            Separate taskAffinity keeps it off MainActivity's back stack.
        -->
        <activity
            android:name=".TilePermissionActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:taskAffinity=".tile" />

        <!-- Required by Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

    </application>

    <!-- Required to query activities that can process text -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
    </queries>

</manifest>